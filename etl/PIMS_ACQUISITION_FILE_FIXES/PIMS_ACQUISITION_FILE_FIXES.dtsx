      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{8B5D1D27-05A2-4BA1-9070-993B4CECFDCF}"
          SQLTask:SqlStatementSource="WITH SafeUpdates AS (&#xA;    SELECT &#xA;        CHILD_AF.ACQUISITION_FILE_ID,&#xA;        MIN(PARENT_AF.REGION_CODE)          AS TARGET_REGION,&#xA;        MIN(PARENT_AF.ACQUISITION_FILE_ID)  AS PARENT_ACQ_FILE_ID&#xA;    FROM dbo.PIMS_ACQUISITION_FILE CHILD_AF&#xA;    INNER JOIN dbo.PIMS_ACQUISITION_FILE PARENT_AF&#xA;        ON CHARINDEX('-', PARENT_AF.LEGACY_FILE_NUMBER) &gt; 0&#xA;        AND CHARINDEX('-', CHILD_AF.LEGACY_FILE_NUMBER) &gt; 0&#xA;        AND LEFT(PARENT_AF.LEGACY_FILE_NUMBER, CHARINDEX('-', PARENT_AF.LEGACY_FILE_NUMBER) - 1)&#xA;           = LEFT(CHILD_AF.LEGACY_FILE_NUMBER, CHARINDEX('-', CHILD_AF.LEGACY_FILE_NUMBER) - 1)&#xA;        AND PARENT_AF.file_no_suffix = 1&#xA;        AND LEFT(PARENT_AF.APP_CREATE_USERID, 3) = LEFT(CHILD_AF.APP_CREATE_USERID, 3)&#xA;    LEFT JOIN dbo.PIMS_PROPERTY_ACQUISITION_FILE CHILD_PAF&#xA;        ON CHILD_PAF.ACQUISITION_FILE_ID = CHILD_AF.ACQUISITION_FILE_ID&#xA;    WHERE LEFT(CHILD_AF.APP_CREATE_USERID, 3) = 'TAP'&#xA;      AND CHILD_AF.file_no_suffix &gt; 1&#xA;      AND CHILD_AF.REGION_CODE = 4&#xA;      AND CHILD_PAF.ACQUISITION_FILE_ID IS NULL&#xA;    GROUP BY CHILD_AF.ACQUISITION_FILE_ID&#xA;    HAVING COUNT(DISTINCT PARENT_AF.REGION_CODE) = 1&#xA;     --  AND MIN(PARENT_AF.REGION_CODE) &lt;&gt; 4&#xA;       AND COUNT(DISTINCT PARENT_AF.ACQUISITION_FILE_ID) = 1   &#xA;)&#xA;UPDATE AF&#xA;SET&#xA;    AF.REGION_CODE                  = S.TARGET_REGION,&#xA;    AF.PRNT_ACQUISITION_FILE_ID     = S.PARENT_ACQ_FILE_ID,&#xA;&#x9;AF.SUBFILE_INTEREST_TYPE_CODE   = 'OTHER',&#xA;    CONCURRENCY_CONTROL_NUMBER      = CONCURRENCY_CONTROL_NUMBER + 1,&#xA;    APP_LAST_UPDATE_USERID          = 'TAP_ETL_FIX_PSP-11357',&#xA;    APP_LAST_UPDATE_TIMESTAMP       = GETDATE()&#xA;FROM dbo.PIMS_ACQUISITION_FILE AF&#xA;INNER JOIN SafeUpdates S ON AF.ACQUISITION_FILE_ID = S.ACQUISITION_FILE_ID;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
