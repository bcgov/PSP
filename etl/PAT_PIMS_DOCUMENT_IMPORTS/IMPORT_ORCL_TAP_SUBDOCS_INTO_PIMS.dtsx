          SQLTask:SqlStatementSource="IF NOT EXISTS (&#xA;    SELECT 1 &#xA;    FROM INFORMATION_SCHEMA.TABLES &#xA;    WHERE TABLE_NAME = 'TAP_SOURCE_SUB_DOCS ' AND TABLE_SCHEMA = 'etl'&#xA;)&#xA;BEGIN&#xA;    CREATE TABLE etl.TAP_SOURCE_SUB_DOCS (&#xA;    [TYPE_DESCRIPTION] nvarchar(500),&#xA;    [FILE_NAME] nvarchar(100),&#xA;    [MULTIMEDIA_OBJECT_ID] numeric(10,0),&#xA;    [DIGITAL_REPRESENTATION] varbinary(max),&#xA;    [CREATE_DATETIME] datetime,&#xA;    [LAST_UPDATE_DATETIME] datetime,&#xA;&#x9;[APP_CREATE_TIMESTAMP] datetime,&#xA;&#x9;[APP_LAST_UPDATE_TIMESTAMP] datetime,&#xA;&#x9;MOT_NUMBER INT&#xA;&#x9;);&#xA;END;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
