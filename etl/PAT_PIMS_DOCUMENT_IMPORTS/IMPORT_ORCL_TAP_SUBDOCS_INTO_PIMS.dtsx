    <DTS:Executable
      DTS:refId="Package\non-null"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{305B8266-1B1C-4360-AF4B-E920D20C8126}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="non-null"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{F6B0B8E0-2D74-4DF1-B41C-236035D3D138}"
          SQLTask:SqlStatementSource="SELECT COUNT(*) FROM dbo.PIMS_DOCUMENT_QUEUE WHERE DOCUMENT IS NOT NULL and APP_CREATE_USERID != 'PIMS_ETL_USER_TAP_SUBDOCS' AND DOCUMENT_QUEUE_STATUS_TYPE_CODE IN ('PENDING','PROCESSING')"
          SQLTask:ResultType="ResultSetType_SingleRow" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ResultBinding
            SQLTask:ResultName="0"
            SQLTask:DtsVariableName="User::PendingCount" />
        </SQLTask:SqlTaskData>
      </DTS:ObjectData>
