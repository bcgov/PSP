      DTS:ObjectName="MAX ID ( PIMS )"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{F6B0B8E0-2D74-4DF1-B41C-236035D3D138}"
          SQLTask:SqlStatementSource=" SELECT &#xA;&#x9;CASE WHEN MAX(MULTIMEDIA_OBJECT_ID) IS NULL THEN 0 ELSE MAX(MULTIMEDIA_OBJECT_ID) END&#xA;FROM etl.TAP_SOURCE_SUB_DOCS"
          SQLTask:ResultType="ResultSetType_SingleRow" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ResultBinding
            SQLTask:ResultName="0"
            SQLTask:DtsVariableName="User::PIMS_MULTIMEDIA_OBJECT_ID_MAX" />
        </SQLTask:SqlTaskData>
      </DTS:ObjectData>
