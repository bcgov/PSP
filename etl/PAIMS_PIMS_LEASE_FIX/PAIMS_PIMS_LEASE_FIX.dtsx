    <DTS:Executable
      DTS:refId="Package\update PIMS_LEASE"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{F1A9C520-02AB-48EF-B3AB-774BD49A4BEB}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="update PIMS_LEASE"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{B56D6EBF-312D-4E60-B6F8-EB511BC76194}"
          SQLTask:SqlStatementSource="-- UPDATE pims_lease STATEMENT&#xA;WITH &#xA;&#xA;IGNORE_LEASE_IDs AS (&#xA;    SELECT DISTINCT &#xA;        A.LEASE_ID&#xA;    FROM dbo.PIMS_LEASE A&#xA;    JOIN dbo.PIMS_LEASE_HIST B&#xA;        ON A.APP_CREATE_USER_DIRECTORY = B.APP_CREATE_USER_DIRECTORY&#xA;    JOIN etl.SRC_PAIMS_LEASE SRC &#xA;        ON A.APP_CREATE_USER_DIRECTORY = SRC.APP_CREATE_USER_DIRECTORY&#xA;    WHERE &#xA;        A.APP_CREATE_USERID IN ( 'PAIMS_ETL_USER','PAIMS_ETL_USER_FIX')&#xA;        AND A.LEASE_PAY_RVBL_TYPE_CODE &lt;&gt; B.LEASE_PAY_RVBL_TYPE_CODE&#xA;        AND B.APP_LAST_UPDATE_USERID NOT IN ( 'PAIMS_ETL_USER', 'PAIMS_ETL_USER_FIX')&#xA;)&#xA;&#xA;UPDATE A&#xA;SET A.LEASE_PAY_RVBL_TYPE_CODE = &#xA;    CASE &#xA;        WHEN TRIM(B.[PROPERTY TENURE TYPE]) = 'TM' THEN 'RCVBL'&#xA;        WHEN TRIM(B.[PROPERTY TENURE TYPE]) = 'TT' THEN 'RCVBL'&#xA;        WHEN TRIM(B.[PROPERTY TENURE TYPE]) = 'PL' THEN 'PYBLMOTI'&#xA;        WHEN TRIM(B.[PROPERTY TENURE TYPE]) = 'CL' THEN 'PYBLBCTFA'&#xA;        WHEN TRIM(B.[PROPERTY TENURE TYPE]) = 'RW' THEN 'RCVBL'&#xA;        WHEN TRIM(B.[PROPERTY TENURE TYPE]) = 'CR' THEN 'RCVBL'&#xA;    END,&#xA;&#x9;APP_LAST_UPDATE_USERID = 'PAIMS_ETL_USER_FIX',&#xA;&#x9;APP_LAST_UPDATE_TIMESTAMP = GETDATE(),&#xA;&#x9;CONCURRENCY_CONTROL_NUMBER = CONCURRENCY_CONTROL_NUMBER + 1&#xA;&#xA;FROM dbo.PIMS_LEASE A&#xA;LEFT JOIN etl.SRC_PAIMS_LEASE B &#xA;    ON TRY_CAST(A.APP_CREATE_USER_DIRECTORY AS INT) = TRY_CAST(B.[PROPERTY_CONTRACT_ID] AS INT)&#xA;WHERE &#xA;    A.APP_CREATE_USERID = 'PAIMS_ETL_USER'&#xA;    AND B.PS_FILE_NO IS NOT NULL&#xA;    AND A.LEASE_ID NOT IN (SELECT LEASE_ID FROM IGNORE_LEASE_IDs);&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
