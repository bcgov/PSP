                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">UPDATE	[dbo].[PIMS_DISPOSITION_SALE]
SET
	[FINAL_CONDITION_REMOVAL_DT] = ?,
	[SALE_COMPLETION_DT] = ?,
    [SALE_FISCAL_YEAR] = ?,
    [SALE_FINAL_AMT] = ?,
