    [REMEDIATION_AMT] = ?,
    [CONCURRENCY_CONTROL_NUMBER] = CONCURRENCY_CONTROL_NUMBER + 1,
	[APP_LAST_UPDATE_TIMESTAMP] = GETUTCDATE()
	WHERE
		[APP_LAST_UPDATE_USERID] = ? 	AND 
		[DISPOSITION_FILE_ID] = ?</property>
