                <component
                  refId="Package\LOAD CODE AND DESCRIPTION\LEVEL 2 - WORK ACTIVITY CODES\LEVEL_2"
                  componentClassID="Microsoft.OLEDBSource"
                  contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
                  description="OLE DB Source"
                  name="LEVEL_2"
                  usesDispositions="true"
                  version="7">
                  <properties>
                    <property
                      dataType="System.Int32"
                      description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                      name="CommandTimeout">0</property>
                    <property
                      dataType="System.String"
                      description="Specifies the name of the database object used to open a rowset."
                      name="OpenRowset"></property>
                    <property
                      dataType="System.String"
                      description="Specifies the variable that contains the name of the database object used to open a rowset."
                      name="OpenRowsetVariable"></property>
                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT 
    CAST(
        CASE 
            WHEN CHARINDEX('-', LEVEL_2) &gt; 0 
            THEN LTRIM(RTRIM(LEFT(LEVEL_2, CHARINDEX('-', LEVEL_2) - 1)))
            ELSE LEVEL_2
        END 
    AS NVARCHAR(20)) AS CODE,

    --CAST(
    --    CASE 
    --        WHEN CHARINDEX('-', LEVEL_2) &gt; 0 
    --        THEN LTRIM(RTRIM(SUBSTRING(LEVEL_2, CHARINDEX('-', LEVEL_2) + 1, LEN(LEVEL_2))))
    --        ELSE NULL
    --    END 
    --AS NVARCHAR(200)) AS DESCRIPTION,

	CAST (LEVEL_2 AS NVARCHAR(200)) AS DESCRIPTION,

    ROW_NUMBER() OVER (
        ORDER BY TRY_CAST(
            LTRIM(RTRIM(LEFT(LEVEL_2, CHARINDEX('-', LEVEL_2) - 1))) AS INT
        )
    ) AS DISPLAY_ORDER

FROM etl.IPS_COST_CODES
ORDER BY DISPLAY_ORDER;</property>
                    <property
                      dataType="System.String"
                      description="The variable that contains the SQL command to be executed."
                      name="SqlCommandVariable"></property>
                    <property
                      dataType="System.Int32"
                      description="Specifies the column code page to use when code page information is unavailable from the data source."
                      name="DefaultCodePage">1252</property>
                    <property
                      dataType="System.Boolean"
                      description="Forces the use of the DefaultCodePage property value when describing character data."
                      name="AlwaysUseDefaultCodePage">false</property>
                    <property
                      dataType="System.Int32"
                      description="Specifies the mode used to access the database."
                      name="AccessMode"
                      typeConverter="AccessMode">2</property>
                    <property
                      dataType="System.String"
                      description="The mappings between the parameters in the SQL command and variables."
                      name="ParameterMapping"></property>
                  </properties>
