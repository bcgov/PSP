      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{4B73A998-03B3-4D9D-8A17-FAEB77F28A18}"
          SQLTask:SqlStatementSource="INSERT INTO PIMS_PROP_ACQ_FL_COMP_REQ_HIST&#xA;(&#xA;_PROP_ACQ_FL_COMP_REQ_HIST_ID,&#xA;EFFECTIVE_DATE_HIST,&#xA;END_DATE_HIST,&#xA;A.PROP_ACQ_FL_COMP_REQ_ID,&#xA;A.PROPERTY_ACQUISITION_FILE_ID,&#xA;A.COMPENSATION_REQUISITION_ID,&#xA;A.CONCURRENCY_CONTROL_NUMBER,&#xA;A.APP_CREATE_TIMESTAMP,&#xA;A.APP_CREATE_USERID,&#xA;A.APP_CREATE_USER_GUID,&#xA;A.APP_CREATE_USER_DIRECTORY,&#xA;A.APP_LAST_UPDATE_TIMESTAMP,&#xA;A.APP_LAST_UPDATE_USERID,&#xA;A.APP_LAST_UPDATE_USER_GUID,&#xA;A.APP_LAST_UPDATE_USER_DIRECTORY,&#xA;A.DB_CREATE_TIMESTAMP,&#xA;A.DB_CREATE_USERID,&#xA;A.DB_LAST_UPDATE_TIMESTAMP,&#xA;A.DB_LAST_UPDATE_USERID&#xA;)&#xA;SELECT&#xA;(NEXT VALUE FOR [PIMS_PROP_ACQ_FL_COMP_REQ_H_ID_SEQ])  AS _PROP_ACQ_FL_COMP_REQ_HIST_ID,&#xA;'1900-01-01 00:00:00.000' as EFFECTIVE_DATE_HIST,&#xA;DATEADD(MINUTE, 1, B.APP_CREATE_TIMESTAMP) AS END_DATE_HIST,&#xA;A.PROP_ACQ_FL_COMP_REQ_ID,&#xA;A.PROPERTY_ACQUISITION_FILE_ID,&#xA;A.COMPENSATION_REQUISITION_ID,&#xA;A.CONCURRENCY_CONTROL_NUMBER,&#xA;A.APP_CREATE_TIMESTAMP,&#xA;A.APP_CREATE_USERID,&#xA;A.APP_CREATE_USER_GUID,&#xA;A.APP_CREATE_USER_DIRECTORY,&#xA;A.APP_LAST_UPDATE_TIMESTAMP,&#xA;A.APP_LAST_UPDATE_USERID,&#xA;A.APP_LAST_UPDATE_USER_GUID,&#xA;A.APP_LAST_UPDATE_USER_DIRECTORY,&#xA;A.DB_CREATE_TIMESTAMP,&#xA;A.DB_CREATE_USERID,&#xA;A.DB_LAST_UPDATE_TIMESTAMP,&#xA;A.DB_LAST_UPDATE_USERID&#xA;&#xA;from PIMS_PROP_ACQ_FL_COMP_REQ A&#xA;&#x9;JOIN [dbo].[PIMS_COMPENSATION_REQUISITION] B&#xA;&#x9;&#x9;ON A.COMPENSATION_REQUISITION_ID = B.COMPENSATION_REQUISITION_ID&#xA;&#x9;--where COMPENSATION_REQUISITION_ID IN (&#xA;&#x9;--select COMPENSATION_REQUISITION_ID from [dbo].[PIMS_COMPENSATION_REQUISITION]&#xA;&#x9;--&#x9;where &#xA;&#x9;--&#x9;APP_CREATE_USERID = 'PAIMS_PIMS_ACQUISITION'&#xA;&#x9;--&#x9;AND IS_DRAFT = 0 -- FINAL&#xA;&#x9;--) &#xA;&#x9;AND&#xA;&#x9;B.APP_CREATE_USERID = 'PAIMS_PIMS_ACQUISITION'&#xA;&#x9;AND B.IS_DRAFT = 0&#xA;&#x9;--AND&#xA;&#x9;--PROP_ACQ_FL_COMP_REQ_ID not in (&#xA;&#x9;--Select PROP_ACQ_FL_COMP_REQ_ID from PIMS_ACQUISITION_FILE_TEAM_HIST&#xA;&#x9;--)&#xA;&#x9;; " xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
