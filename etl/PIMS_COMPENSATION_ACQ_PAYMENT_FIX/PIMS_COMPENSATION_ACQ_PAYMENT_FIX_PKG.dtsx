      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{4B73A998-03B3-4D9D-8A17-FAEB77F28A18}"
          SQLTask:SqlStatementSource="INSERT INTO dbo.PIMS_COMP_REQ_ACQ_PAYEE_HIST&#xA;(&#xA;_COMP_REQ_ACQ_PAYEE_HIST_ID,&#xA;EFFECTIVE_DATE_HIST,&#xA;END_DATE_HIST,&#xA;COMP_REQ_ACQ_PAYEE_ID,&#xA;COMPENSATION_REQUISITION_ID,&#xA;ACQUISITION_OWNER_ID,&#xA;INTEREST_HOLDER_ID,&#xA;ACQUISITION_FILE_TEAM_ID,&#xA;LEGACY_PAYEE,&#xA;CONCURRENCY_CONTROL_NUMBER,&#xA;APP_CREATE_TIMESTAMP,&#xA;APP_CREATE_USERID,&#xA;APP_CREATE_USER_GUID,&#xA;APP_CREATE_USER_DIRECTORY,&#xA;APP_LAST_UPDATE_TIMESTAMP,&#xA;APP_LAST_UPDATE_USERID,&#xA;APP_LAST_UPDATE_USER_GUID,&#xA;APP_LAST_UPDATE_USER_DIRECTORY,&#xA;DB_CREATE_TIMESTAMP,&#xA;DB_CREATE_USERID,&#xA;DB_LAST_UPDATE_TIMESTAMP,&#xA;DB_LAST_UPDATE_USERID&#xA;&#xA;)&#xA;select &#xA;(NEXT VALUE FOR [PIMS_COMP_REQ_ACQ_PAYEE_H_ID_SEQ]) AS _COMP_REQ_ACQ_PAYEE_HIST_ID,&#xA;'1900-01-01 00:00:00.000' as EFFECTIVE_DATE_HIST,&#xA;DATEADD(MINUTE, 1, B.APP_CREATE_TIMESTAMP) AS END_DATE_HIST,&#xA;A.COMP_REQ_ACQ_PAYEE_ID,&#xA;A.COMPENSATION_REQUISITION_ID,&#xA;A.ACQUISITION_OWNER_ID,&#xA;A.INTEREST_HOLDER_ID,&#xA;A.ACQUISITION_FILE_TEAM_ID,&#xA;A.LEGACY_PAYEE,&#xA;A.CONCURRENCY_CONTROL_NUMBER,&#xA;A.APP_CREATE_TIMESTAMP,&#xA;A.APP_CREATE_USERID,&#xA;A.APP_CREATE_USER_GUID,&#xA;A.APP_CREATE_USER_DIRECTORY,&#xA;A.APP_LAST_UPDATE_TIMESTAMP,&#xA;A.APP_LAST_UPDATE_USERID,&#xA;A.APP_LAST_UPDATE_USER_GUID,&#xA;A.APP_LAST_UPDATE_USER_DIRECTORY,&#xA;A.DB_CREATE_TIMESTAMP,&#xA;A.DB_CREATE_USERID,&#xA;A.DB_LAST_UPDATE_TIMESTAMP,&#xA;A.DB_LAST_UPDATE_USERID&#xA;from PIMS_COMP_REQ_ACQ_PAYEE A&#xA;&#x9;JOIN [dbo].[PIMS_COMPENSATION_REQUISITION] B&#xA;&#x9;&#x9;ON A.COMPENSATION_REQUISITION_ID = B.COMPENSATION_REQUISITION_ID&#xA;&#x9;--where A.COMPENSATION_REQUISITION_ID IN (&#xA;&#x9;--&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;select COMPENSATION_REQUISITION_ID from [dbo].[PIMS_COMPENSATION_REQUISITION]&#xA;&#x9;--&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;where &#xA;&#x9;--&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;APP_CREATE_USERID = 'PAIMS_PIMS_ACQUISITION'&#xA;&#x9;--&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AND IS_DRAFT = 0 -- FINAL&#xA;&#x9;--&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;) &#xA;&#x9;AND&#xA;&#x9;B.APP_CREATE_USERID = 'PAIMS_PIMS_ACQUISITION'&#xA;&#x9;AND B.IS_DRAFT = 0 &#xA;&#x9;&#xA;&#x9;--AND&#xA;&#x9;--COMP_REQ_ACQ_PAYEE_ID not in (&#xA;&#x9;--Select COMP_REQ_ACQ_PAYEE_ID from PIMS_COMP_REQ_ACQ_PAYEE_HIST&#xA;&#x9;--)&#xA;;&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
