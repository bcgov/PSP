          SQLTask:Connection="{4B73A998-03B3-4D9D-8A17-FAEB77F28A18}"
          SQLTask:SqlStatementSource="INSERT INTO [dbo].[PIMS_COMPENSATION_REQUISITION_HIST]&#xA;(&#xA;[_COMPENSATION_REQUISITION_HIST_ID],&#xA;EFFECTIVE_DATE_HIST,&#xA;END_DATE_HIST,&#xA;COMPENSATION_REQUISITION_ID,&#xA;ACQUISITION_FILE_ID,&#xA;&#xA;&#xA;ACQUISITION_OWNER_ID,&#xA;INTEREST_HOLDER_ID,&#xA;ACQUISITION_FILE_TEAM_ID,&#xA;CHART_OF_ACCOUNTS_ID,&#xA;RESPONSIBILITY_ID,&#xA;YEARLY_FINANCIAL_ID,&#xA;ALTERNATE_PROJECT_ID,&#xA;&#xA;&#xA;LEGACY_PAYEE,&#xA;IS_DRAFT,&#xA;IS_PAYMENT_IN_TRUST,&#xA;GST_NUMBER,&#xA;FISCAL_YEAR,&#xA;AGREEMENT_DT,&#xA;EXPROP_NOTICE_SERVED_DT,&#xA;EXPROP_VESTING_DT,&#xA;GENERATION_DT,&#xA;FINALIZED_DATE,&#xA;ADV_PMT_SERVED_DT,&#xA;SPECIAL_INSTRUCTION,&#xA;DETAILED_REMARKS,&#xA;&#xA;&#xA;&#xA;&#xA;IS_DISABLED,&#xA;CONCURRENCY_CONTROL_NUMBER,&#xA;APP_CREATE_TIMESTAMP,&#xA;APP_CREATE_USERID,&#xA;APP_CREATE_USER_GUID,&#xA;APP_CREATE_USER_DIRECTORY,&#xA;APP_LAST_UPDATE_TIMESTAMP,&#xA;APP_LAST_UPDATE_USERID,&#xA;APP_LAST_UPDATE_USER_GUID,&#xA;APP_LAST_UPDATE_USER_DIRECTORY,&#xA;DB_CREATE_TIMESTAMP,&#xA;DB_CREATE_USERID,&#xA;DB_LAST_UPDATE_TIMESTAMP,&#xA;DB_LAST_UPDATE_USERID,&#xA;LEASE_ID&#xA;)&#xA;select&#xA;(next value for [dbo].[PIMS_COMPENSATION_REQUISITION_H_ID_SEQ]) as [_COMPENSATION_REQUISITION_HIST_ID],&#xA;CAST('1900-01-01 00:00:00.000' AS datetime) as EFFECTIVE_DATE_HIST,&#xA;NULL AS END_DATE_HIST,&#xA;COMPENSATION_REQUISITION_ID,&#xA;ACQUISITION_FILE_ID,&#xA;&#xA;NULL AS ACQUISITION_OWNER_ID,&#xA;NULL AS INTEREST_HOLDER_ID,&#xA;NULL AS ACQUISITION_FILE_TEAM_ID,&#xA;CHART_OF_ACCOUNTS_ID,&#xA;RESPONSIBILITY_ID,&#xA;YEARLY_FINANCIAL_ID,&#xA;ALTERNATE_PROJECT_ID,&#xA;&#xA;NULL AS LEGACY_PAYEE,&#xA;IS_DRAFT,&#xA;IS_PAYMENT_IN_TRUST,&#xA;GST_NUMBER,&#xA;FISCAL_YEAR,&#xA;AGREEMENT_DT,&#xA;NULL AS EXPROP_NOTICE_SERVED_DT,&#xA;NULL AS EXPROP_VESTING_DT,&#xA;GENERATION_DT,&#xA;FINALIZED_DATE,&#xA;NULL AS ADV_PMT_SERVED_DT,&#xA;SPECIAL_INSTRUCTION,&#xA;DETAILED_REMARKS,&#xA;&#xA;&#xA;IS_DISABLED,&#xA;CONCURRENCY_CONTROL_NUMBER,&#xA;APP_CREATE_TIMESTAMP,&#xA;APP_CREATE_USERID,&#xA;APP_CREATE_USER_GUID,&#xA;APP_CREATE_USER_DIRECTORY,&#xA;APP_LAST_UPDATE_TIMESTAMP,&#xA;APP_LAST_UPDATE_USERID,&#xA;APP_LAST_UPDATE_USER_GUID,&#xA;APP_LAST_UPDATE_USER_DIRECTORY,&#xA;DB_CREATE_TIMESTAMP,&#xA;DB_CREATE_USERID,&#xA;DB_LAST_UPDATE_TIMESTAMP,&#xA;DB_LAST_UPDATE_USERID,&#xA;LEASE_ID&#xA;from [dbo].[PIMS_COMPENSATION_REQUISITION]&#xA;where &#xA;APP_CREATE_USERID = 'PAIMS_PIMS_ACQUISITION'&#xA;AND IS_DRAFT = 0&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
