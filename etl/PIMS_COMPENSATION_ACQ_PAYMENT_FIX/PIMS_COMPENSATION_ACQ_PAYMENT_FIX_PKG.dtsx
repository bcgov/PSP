        <SQLTask:SqlTaskData
          SQLTask:Connection="{4B73A998-03B3-4D9D-8A17-FAEB77F28A18}"
          SQLTask:SqlStatementSource="INSERT INTO PIMS_INTEREST_HOLDER_HIST&#xA;(&#xA;_INTEREST_HOLDER_HIST_ID,&#xA;EFFECTIVE_DATE_HIST,&#xA;END_DATE_HIST,&#xA;INTEREST_HOLDER_ID,&#xA;ACQUISITION_FILE_ID,&#xA;PERSON_ID,&#xA;ORGANIZATION_ID,&#xA;PRIMARY_CONTACT_ID,&#xA;INTEREST_HOLDER_TYPE_CODE,&#xA;[COMMENT],&#xA;IS_DISABLED,&#xA;CONCURRENCY_CONTROL_NUMBER,&#xA;APP_CREATE_TIMESTAMP,&#xA;APP_CREATE_USERID,&#xA;APP_CREATE_USER_GUID,&#xA;APP_CREATE_USER_DIRECTORY,&#xA;APP_LAST_UPDATE_TIMESTAMP,&#xA;APP_LAST_UPDATE_USERID,&#xA;APP_LAST_UPDATE_USER_GUID,&#xA;APP_LAST_UPDATE_USER_DIRECTORY,&#xA;DB_CREATE_TIMESTAMP,&#xA;DB_CREATE_USERID,&#xA;DB_LAST_UPDATE_TIMESTAMP,&#xA;DB_LAST_UPDATE_USERID&#xA;&#xA;)&#xA;&#xA;SELECT&#xA;(NEXT VALUE FOR [PIMS_INTEREST_HOLDER_H_ID_SEQ])  AS _INTEREST_HOLDER_HIST_ID,&#xA;'1900-01-01 00:00:00.000' as EFFECTIVE_DATE_HIST,&#xA;'1900-01-02 00:00:00.000' as END_DATE_HIST,&#xA;INTEREST_HOLDER_ID,&#xA;ACQUISITION_FILE_ID,&#xA;PERSON_ID,&#xA;ORGANIZATION_ID,&#xA;PRIMARY_CONTACT_ID,&#xA;INTEREST_HOLDER_TYPE_CODE,&#xA;COMMENT,&#xA;IS_DISABLED,&#xA;CONCURRENCY_CONTROL_NUMBER,&#xA;APP_CREATE_TIMESTAMP,&#xA;APP_CREATE_USERID,&#xA;APP_CREATE_USER_GUID,&#xA;APP_CREATE_USER_DIRECTORY,&#xA;APP_LAST_UPDATE_TIMESTAMP,&#xA;APP_LAST_UPDATE_USERID,&#xA;APP_LAST_UPDATE_USER_GUID,&#xA;APP_LAST_UPDATE_USER_DIRECTORY,&#xA;DB_CREATE_TIMESTAMP,&#xA;DB_CREATE_USERID,&#xA;DB_LAST_UPDATE_TIMESTAMP,&#xA;DB_LAST_UPDATE_USERID&#xA;from PIMS_INTEREST_HOLDER&#xA;&#x9;where ACQUISITION_FILE_ID IN (&#xA;&#x9;select ACQUISITION_FILE_ID from [dbo].[PIMS_COMPENSATION_REQUISITION]&#xA;&#x9;&#x9;where &#xA;&#x9;&#x9;APP_CREATE_USERID = 'PAIMS_PIMS_ACQUISITION'&#xA;&#x9;&#x9;AND IS_DRAFT = 0 -- FINAL&#xA;&#x9;) &#xA;&#x9;--AND&#xA;&#x9;--INTEREST_HOLDER_ID not in (&#xA;&#x9;--Select INTEREST_HOLDER_ID from PIMS_INTEREST_HOLDER_HIST&#xA;&#x9;--)&#xA;;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\PIMS_PROPERTY"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{F731D3CF-307F-499A-9A8C-93D11CEC4B60}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="PIMS_PROPERTY"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{4B73A998-03B3-4D9D-8A17-FAEB77F28A18}"
          SQLTask:SqlStatementSource="&#xA;WITH X AS&#xA;(&#xA;SELECT&#xA;   PP.PROPERTY_ID&#xA;from PIMS_PROPERTY PP&#xA;&#x9;&#x9;JOIN PIMS_PROPERTY_ACQUISITION_FILE PPAF ON PP.PROPERTY_ID = PPAF.PROPERTY_ID&#xA;&#x9;&#x9;JOIN PIMS_ACQUISITION_FILE PAF ON PAF.ACQUISITION_FILE_ID = PPAF.ACQUISITION_FILE_ID&#xA;&#x9;where PAF.ACQUISITION_FILE_ID IN (&#xA;&#x9;select ACQUISITION_FILE_ID from [dbo].[PIMS_COMPENSATION_REQUISITION]&#xA;&#x9;&#x9;where &#xA;&#x9;&#x9;APP_CREATE_USERID = 'PAIMS_PIMS_ACQUISITION'&#xA;&#x9;&#x9;AND IS_DRAFT = 0 -- FINAL&#xA;&#x9;) &#xA;&#x9;--AND&#xA;&#x9;--PP.PROPERTY_ID not in (&#xA;&#x9;--Select PROPERTY_ID from PIMS_PROPERTY_HIST&#xA;&#x9;--)&#xA;)&#xA;&#xA;&#xA;INSERT INTO dbo.PIMS_PROPERTY_HIST&#xA;(&#xA;_PROPERTY_HIST_ID,&#xA;EFFECTIVE_DATE_HIST,&#xA;END_DATE_HIST,&#xA;PROPERTY_ID,&#xA;PROPERTY_MANAGER_ID,&#xA;PROP_MGMT_ORG_ID,&#xA;PROPERTY_TYPE_CODE,&#xA;ADDRESS_ID,&#xA;REGION_CODE,&#xA;DISTRICT_CODE,&#xA;PROPERTY_AREA_UNIT_TYPE_CODE,&#xA;PROPERTY_DATA_SOURCE_TYPE_CODE,&#xA;PROPERTY_STATUS_TYPE_CODE,&#xA;SURPLUS_DECLARATION_TYPE_CODE,&#xA;VOLUMETRIC_TYPE_CODE,&#xA;VOLUME_UNIT_TYPE_CODE,&#xA;PPH_STATUS_TYPE_CODE,&#xA;PROPERTY_CLASSIFICATION_TYPE_CODE,&#xA;PROPERTY_DATA_SOURCE_EFFECTIVE_DATE,&#xA;[NAME],&#xA;[DESCRIPTION],&#xA;PID,&#xA;PIN,&#xA;FILE_NUMBER,&#xA;FILE_NUMBER_SUFFIX,&#xA;LAND_AREA,&#xA;GENERAL_LOCATION,&#xA;SURVEY_PLAN_NUMBER,&#xA;ENCUMBRANCE_REASON,&#xA;SURPLUS_DECLARATION_COMMENT,&#xA;SURPLUS_DECLARATION_DATE,&#xA;MUNICIPAL_ZONING,&#xA;IS_VOLUMETRIC_PARCEL,&#xA;VOLUMETRIC_MEASUREMENT,&#xA;IS_OWNED,&#xA;IS_PROPERTY_OF_INTEREST,&#xA;IS_VISIBLE_TO_OTHER_AGENCIES,&#xA;IS_SENSITIVE,&#xA;IS_PROVINCIAL_PUBLIC_HWY,&#xA;PPH_STATUS_UPDATE_USERID,&#xA;PPH_STATUS_UPDATE_TIMESTAMP,&#xA;PPH_STATUS_UPDATE_USER_GUID,&#xA;IS_RWY_BELT_DOM_PATENT,&#xA;ZONING,&#xA;ZONING_POTENTIAL,&#xA;ADDITIONAL_DETAILS,&#xA;IS_UTILITIES_PAYABLE,&#xA;IS_TAXES_PAYABLE,&#xA;BAND_NAME,&#xA;RESERVE_NAME,&#xA;CONCURRENCY_CONTROL_NUMBER,&#xA;APP_CREATE_TIMESTAMP,&#xA;APP_CREATE_USERID,&#xA;APP_CREATE_USER_GUID,&#xA;APP_CREATE_USER_DIRECTORY,&#xA;APP_LAST_UPDATE_TIMESTAMP,&#xA;APP_LAST_UPDATE_USERID,&#xA;APP_LAST_UPDATE_USER_GUID,&#xA;APP_LAST_UPDATE_USER_DIRECTORY,&#xA;DB_CREATE_TIMESTAMP,&#xA;DB_CREATE_USERID,&#xA;DB_LAST_UPDATE_TIMESTAMP,&#xA;DB_LAST_UPDATE_USERID,&#xA;IS_DISPOSED,&#xA;IS_OTHER_INTEREST,&#xA;IS_RETIRED,&#xA;LAND_LEGAL_DESCRIPTION,&#xA;NOTES,&#xA;UTILITY_RESPONSIBILITY_TYPE_CODE,&#xA;TAX_RESPONSIBILITY_TYPE_CODE,&#xA;GLOBAL_UID&#xA;&#xA;&#xA;)&#xA;SELECT&#xA;(NEXT VALUE FOR [PIMS_PROPERTY_H_ID_SEQ])  AS _PROPERTY_HIST_ID,&#xA;'1900-01-01 00:00:00.000' as EFFECTIVE_DATE_HIST,&#xA;'1900-01-02 00:00:00.000' as END_DATE_HIST,&#xA;PP.PROPERTY_ID,&#xA;NULL AS PROPERTY_MANAGER_ID,&#xA;NULL AS PROP_MGMT_ORG_ID,&#xA;PP.PROPERTY_TYPE_CODE,&#xA;PP.ADDRESS_ID,&#xA;PP.REGION_CODE,&#xA;PP.DISTRICT_CODE,&#xA;PP.PROPERTY_AREA_UNIT_TYPE_CODE,&#xA;PP.PROPERTY_DATA_SOURCE_TYPE_CODE,&#xA;PP.PROPERTY_STATUS_TYPE_CODE,&#xA;PP.SURPLUS_DECLARATION_TYPE_CODE,&#xA;PP.VOLUMETRIC_TYPE_CODE,&#xA;PP.VOLUME_UNIT_TYPE_CODE,&#xA;PP.PPH_STATUS_TYPE_CODE,&#xA;NULL AS PROPERTY_CLASSIFICATION_TYPE_CODE,&#xA;PP.PROPERTY_DATA_SOURCE_EFFECTIVE_DATE,&#xA;NULL AS [NAME],&#xA;NULL AS [DESCRIPTION],&#xA;PP.PID,&#xA;PP.PIN,&#xA;PP.FILE_NUMBER,&#xA;PP.FILE_NUMBER_SUFFIX,&#xA;PP.LAND_AREA,&#xA;PP.GENERAL_LOCATION,&#xA;PP.SURVEY_PLAN_NUMBER,&#xA;NULL AS ENCUMBRANCE_REASON,&#xA;PP.SURPLUS_DECLARATION_COMMENT,&#xA;PP.SURPLUS_DECLARATION_DATE,&#xA;PP.MUNICIPAL_ZONING,&#xA;PP.IS_VOLUMETRIC_PARCEL,&#xA;PP.VOLUMETRIC_MEASUREMENT,&#xA;PP.IS_OWNED,&#xA;NULL AS IS_PROPERTY_OF_INTEREST,&#xA;NULL AS IS_VISIBLE_TO_OTHER_AGENCIES,&#xA;NULL AS IS_SENSITIVE,&#xA;NULL AS IS_PROVINCIAL_PUBLIC_HWY,&#xA;PP.PPH_STATUS_UPDATE_USERID,&#xA;PP.PPH_STATUS_UPDATE_TIMESTAMP,&#xA;PP.PPH_STATUS_UPDATE_USER_GUID,&#xA;PP.IS_RWY_BELT_DOM_PATENT,&#xA;NULL AS ZONING,&#xA;NULL AS ZONING_POTENTIAL,&#xA;PP.ADDITIONAL_DETAILS,&#xA;PP.IS_UTILITIES_PAYABLE,&#xA;PP.IS_TAXES_PAYABLE,&#xA;PP.BAND_NAME,&#xA;PP.RESERVE_NAME,&#xA;PP.CONCURRENCY_CONTROL_NUMBER,&#xA;PP.APP_CREATE_TIMESTAMP,&#xA;PP.APP_CREATE_USERID,&#xA;PP.APP_CREATE_USER_GUID,&#xA;PP.APP_CREATE_USER_DIRECTORY,&#xA;PP.APP_LAST_UPDATE_TIMESTAMP,&#xA;PP.APP_LAST_UPDATE_USERID,&#xA;PP.APP_LAST_UPDATE_USER_GUID,&#xA;PP.APP_LAST_UPDATE_USER_DIRECTORY,&#xA;PP.DB_CREATE_TIMESTAMP,&#xA;PP.DB_CREATE_USERID,&#xA;PP.DB_LAST_UPDATE_TIMESTAMP,&#xA;PP.DB_LAST_UPDATE_USERID,&#xA;NULL AS IS_DISPOSED,&#xA;NULL AS IS_OTHER_INTEREST,&#xA;PP.IS_RETIRED,&#xA;PP.LAND_LEGAL_DESCRIPTION,&#xA;NULL AS NOTES,&#xA;PP.UTILITY_RESPONSIBILITY_TYPE_CODE,&#xA;PP.TAX_RESPONSIBILITY_TYPE_CODE,&#xA;PP.GLOBAL_UID&#xA;FROM PIMS_PROPERTY PP WHERE EXISTS ( Select PROPERTY_ID FROM X )&#xA;;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\PIMS_PROPERTY_ACQUISITION_FILE"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{2A8A4AE9-5A39-4516-A700-FE3F82BBA7D8}"
