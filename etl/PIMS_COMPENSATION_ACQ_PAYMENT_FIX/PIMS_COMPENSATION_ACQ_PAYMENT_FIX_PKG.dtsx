      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{4B73A998-03B3-4D9D-8A17-FAEB77F28A18}"
          SQLTask:SqlStatementSource="INSERT INTO PIMS_PROPERTY_ACQUISITION_FILE_HIST&#xA;(&#xA;_PROPERTY_ACQUISITION_FILE_HIST_ID,&#xA;EFFECTIVE_DATE_HIST,&#xA;END_DATE_HIST,&#xA;PROPERTY_ACQUISITION_FILE_ID,&#xA;ACQUISITION_FILE_ID,&#xA;PROPERTY_ID,&#xA;PROPERTY_NAME,&#xA;DISPLAY_ORDER,&#xA;CONCURRENCY_CONTROL_NUMBER,&#xA;APP_CREATE_TIMESTAMP,&#xA;APP_CREATE_USERID,&#xA;APP_CREATE_USER_GUID,&#xA;APP_CREATE_USER_DIRECTORY,&#xA;APP_LAST_UPDATE_TIMESTAMP,&#xA;APP_LAST_UPDATE_USERID,&#xA;APP_LAST_UPDATE_USER_GUID,&#xA;APP_LAST_UPDATE_USER_DIRECTORY,&#xA;DB_CREATE_TIMESTAMP,&#xA;DB_CREATE_USERID,&#xA;DB_LAST_UPDATE_TIMESTAMP,&#xA;DB_LAST_UPDATE_USERID&#xA;&#xA;)&#xA;SELECT&#xA;(NEXT VALUE FOR [PIMS_PROPERTY_ACQUISITION_FILE_H_ID_SEQ])  AS _PROPERTY_ACQUISITION_FILE_HIST_ID,&#xA;'1900-01-01 00:00:00.000' as EFFECTIVE_DATE_HIST,&#xA;'1900-01-02 00:00:00.000' as END_DATE_HIST,&#xA;PROPERTY_ACQUISITION_FILE_ID,&#xA;ACQUISITION_FILE_ID,&#xA;PROPERTY_ID,&#xA;PROPERTY_NAME,&#xA;DISPLAY_ORDER,&#xA;CONCURRENCY_CONTROL_NUMBER,&#xA;APP_CREATE_TIMESTAMP,&#xA;APP_CREATE_USERID,&#xA;APP_CREATE_USER_GUID,&#xA;APP_CREATE_USER_DIRECTORY,&#xA;APP_LAST_UPDATE_TIMESTAMP,&#xA;APP_LAST_UPDATE_USERID,&#xA;APP_LAST_UPDATE_USER_GUID,&#xA;APP_LAST_UPDATE_USER_DIRECTORY,&#xA;DB_CREATE_TIMESTAMP,&#xA;DB_CREATE_USERID,&#xA;DB_LAST_UPDATE_TIMESTAMP,&#xA;DB_LAST_UPDATE_USERID&#xA;&#xA;from PIMS_PROPERTY_ACQUISITION_FILE&#xA;&#x9;where ACQUISITION_FILE_ID IN (&#xA;&#x9;select ACQUISITION_FILE_ID from [dbo].[PIMS_COMPENSATION_REQUISITION]&#xA;&#x9;&#x9;where &#xA;&#x9;&#x9;APP_CREATE_USERID = 'PAIMS_PIMS_ACQUISITION'&#xA;&#x9;&#x9;AND IS_DRAFT = 0 -- FINAL&#xA;&#x9;) &#xA;&#x9;--AND&#xA;&#x9;--PROPERTY_ACQUISITION_FILE_ID not in (&#xA;&#x9;--Select PROPERTY_ACQUISITION_FILE_ID from PIMS_PROPERTY_ACQUISITION_FILE_HIST&#xA;&#x9;--)&#xA;&#x9;;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
