      <DTS:Variables />
      <DTS:Executables>
        <DTS:Executable
          DTS:refId="Package\mot_number NOT NULL Case\GWP_NOT_NULL"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{2871e012-352c-4633-bb2d-e4a790abdda4}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="GWP_NOT_NULL"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{B06732EE-E98B-45E4-9826-B822D8836FA1}"
              SQLTask:SqlStatementSource="INSERT INTO dbo.PIMS_ACQUISITION_FILE_DOCUMENT (&#xA;    DOCUMENT_ID,&#xA;    ACQUISITION_FILE_ID,&#xA;    APP_CREATE_USERID,&#xA;    APP_CREATE_TIMESTAMP,&#xA;    APP_LAST_UPDATE_USERID,&#xA;    APP_LAST_UPDATE_TIMESTAMP&#xA;)&#xA;SELECT&#xA;    p.DOCUMENT_ID,&#xA;    p.ACQUISITION_FILE_ID,&#xA;    'GWP_ETL',&#xA;    GETUTCDATE(),&#xA;    'GWP_ETL',&#xA;    GETUTCDATE()&#xA;FROM (&#xA;    SELECT DISTINCT&#xA;        d.DOCUMENT_ID,&#xA;        d.LAND_PARCEL_ID,&#xA;        d.MOT_NUMBER,&#xA;        d.LEGACY_FILE_NUMBER,&#xA;        d.PID,&#xA;        af.ACQUISITION_FILE_ID&#xA;    FROM (&#xA;        SELECT src.*&#xA;        FROM (&#xA;            SELECT DISTINCT&#xA;                CONVERT(INT, A.LAND_PARCEL_ID) AS LAND_PARCEL_ID,&#xA;                TRY_CONVERT(BIGINT, A.MOT_NUMBER) AS MOT_NUMBER,&#xA;                CASE&#xA;                    WHEN A.MOT_NUMBER IS NULL THEN CONVERT(VARCHAR(50), CONCAT(CONVERT(INT, A.LAND_PARCEL_ID), '-', 'NULL'))&#xA;                    WHEN TRY_CONVERT(BIGINT, A.MOT_NUMBER) IS NOT NULL THEN CONVERT(VARCHAR(50), CONCAT(CONVERT(INT, A.LAND_PARCEL_ID), '-', TRY_CONVERT(BIGINT, A.MOT_NUMBER)))&#xA;                    ELSE CONVERT(VARCHAR(50), CONCAT(CONVERT(INT, A.LAND_PARCEL_ID), '-', LTRIM(RTRIM(CONVERT(VARCHAR(50), A.MOT_NUMBER)))))&#xA;                END AS LEGACY_FILE_NUMBER,&#xA;                B.DOCUMENT_ID,&#xA;                slp.PID&#xA;            FROM etl.GWP_SOURCE_LAND_PARCEL A&#xA;            JOIN dbo.PIMS_DOCUMENT B&#xA;                ON A.MULTIMEDIA_OBJECT_ID = B.DOCUMENT_EXTERNAL_ID&#xA;            JOIN etl.SOURCE_LAND_PARCEL slp&#xA;                ON CONVERT(INT, slp.LAND_PARCEL_ID) = CONVERT(INT, A.LAND_PARCEL_ID)&#xA;               AND slp.SOURCE = 'GWP'&#xA;            WHERE B.DOCUMENT_ID NOT IN (&#xA;                SELECT DOCUMENT_ID&#xA;                FROM dbo.PIMS_ACQUISITION_FILE_DOCUMENT&#xA;                WHERE APP_CREATE_USERID LIKE '%GWP%'&#xA;            )&#xA;        ) src&#xA;        WHERE NOT EXISTS (&#xA;            SELECT 1&#xA;            FROM dbo.PIMS_ACQUISITION_FILE af_existing&#xA;            WHERE CONVERT(VARCHAR(50), af_existing.LEGACY_FILE_NUMBER) = src.LEGACY_FILE_NUMBER&#xA;              AND LEFT(af_existing.APP_CREATE_USERID, 3) = 'GWP'&#xA;        )&#xA;    ) d&#xA;    JOIN dbo.PIMS_PROPERTY pp&#xA;        ON pp.PID = TRY_CONVERT(INT, d.PID)&#xA;    JOIN dbo.PIMS_PROPERTY_ACQUISITION_FILE ppaf&#xA;        ON ppaf.PROPERTY_ID = pp.PROPERTY_ID&#xA;    JOIN dbo.PIMS_ACQUISITION_FILE af&#xA;        ON af.ACQUISITION_FILE_ID = ppaf.ACQUISITION_FILE_ID&#xA;    WHERE af.APP_CREATE_USERID LIKE '%PAIMS_PIMS_ACQUISITION%'&#xA;      AND NOT EXISTS (&#xA;          SELECT 1&#xA;          FROM dbo.PIMS_ACQUISITION_FILE_DOCUMENT afd&#xA;          WHERE afd.DOCUMENT_ID = d.DOCUMENT_ID&#xA;            AND afd.ACQUISITION_FILE_ID = af.ACQUISITION_FILE_ID&#xA;      )&#xA;) p;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\mot_number NOT NULL Case\PAT_NOT_NULL"
