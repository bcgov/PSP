      <DTS:Variables />
      <DTS:Executables>
        <DTS:Executable
          DTS:refId="Package\mot_number NULL Case\GWP"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{655840BB-1625-4F6C-82E6-C0E49CA21CB7}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="GWP"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{B06732EE-E98B-45E4-9826-B822D8836FA1}"
              SQLTask:SqlStatementSource="-- PSP-11073 Fix: Problem 2 — PAIMS Fallback Document Linking for GWP&#xA;&#xA;WITH GWP_NullMot_Docs AS (&#xA;    SELECT&#xA;        CONVERT(INT, A.LAND_PARCEL_ID) AS LAND_PARCEL_ID,&#xA;        CONVERT(VARCHAR(50), CONCAT(CONVERT(INT, A.LAND_PARCEL_ID), '-', 'NULL')) AS LEGACY_FILE_NUMBER,&#xA;        B.DOCUMENT_ID,&#xA;        slp.PID&#xA;    FROM etl.GWP_SOURCE_LAND_PARCEL A&#xA;    JOIN dbo.PIMS_DOCUMENT B&#xA;        ON A.MULTIMEDIA_OBJECT_ID = B.DOCUMENT_EXTERNAL_ID&#xA;    JOIN etl.SOURCE_LAND_PARCEL slp&#xA;        ON CONVERT(INT, slp.LAND_PARCEL_ID) = CONVERT(INT, A.LAND_PARCEL_ID)&#xA;        AND slp.SOURCE = 'GWP'&#xA;    WHERE A.MOT_NUMBER IS NULL&#xA;      -- Exclude documents already linked&#xA;      AND B.DOCUMENT_ID NOT IN (&#xA;          SELECT DOCUMENT_ID&#xA;          FROM dbo.PIMS_ACQUISITION_FILE_DOCUMENT&#xA;          WHERE APP_CREATE_USERID LIKE '%GWP%'&#xA;      )&#xA;      -- Exclude documents that already have a GWP ETL acquisition file&#xA;      AND NOT EXISTS (&#xA;          SELECT 1&#xA;          FROM dbo.PIMS_ACQUISITION_FILE af&#xA;          WHERE CONVERT(VARCHAR(50), af.LEGACY_FILE_NUMBER) = CONVERT(VARCHAR(50), CONCAT(CONVERT(INT, A.LAND_PARCEL_ID), '-', 'NULL'))&#xA;            AND LEFT(af.APP_CREATE_USERID, 3) = 'GWP'&#xA;      )&#xA;),&#xA;PAIMS_Matches AS (&#xA;    SELECT&#xA;        g.DOCUMENT_ID,&#xA;        g.LAND_PARCEL_ID,&#xA;        af.ACQUISITION_FILE_ID&#xA;    FROM GWP_NullMot_Docs g&#xA;    JOIN dbo.PIMS_PROPERTY pp&#xA;        ON pp.PID = TRY_CONVERT(int, g.PID)&#xA;    JOIN dbo.PIMS_PROPERTY_ACQUISITION_FILE ppaf&#xA;        ON ppaf.PROPERTY_ID = pp.PROPERTY_ID&#xA;    JOIN dbo.PIMS_ACQUISITION_FILE af&#xA;        ON af.ACQUISITION_FILE_ID = ppaf.ACQUISITION_FILE_ID&#xA;    WHERE af.APP_CREATE_USERID LIKE '%PAIMS_PIMS_ACQUISITION%'&#xA;)&#xA;&#xA;-- Preview before inserting&#xA;--SELECT&#xA;--    pm.DOCUMENT_ID,&#xA;--    pm.ACQUISITION_FILE_ID,&#xA;--    pm.LAND_PARCEL_ID,&#xA;--    'GWP_ETL' AS APP_CREATE_USERID&#xA;--FROM PAIMS_Matches pm&#xA;--ORDER BY pm.LAND_PARCEL_ID, pm.DOCUMENT_ID&#xA;--;&#xA;&#xA;-- INSERT (run after validating preview above)&#xA;&#xA;INSERT INTO dbo.PIMS_ACQUISITION_FILE_DOCUMENT (&#xA;    DOCUMENT_ID,&#xA;    ACQUISITION_FILE_ID,&#xA;    APP_CREATE_USERID,&#xA;    APP_CREATE_TIMESTAMP,&#xA;    APP_LAST_UPDATE_USERID,&#xA;    APP_LAST_UPDATE_TIMESTAMP&#xA;)&#xA;SELECT&#xA;    pm.DOCUMENT_ID,&#xA;    pm.ACQUISITION_FILE_ID,&#xA;    'GWP_ETL',&#xA;    GETUTCDATE(),&#xA;    'GWP_ETL',&#xA;    GETUTCDATE()&#xA;FROM PAIMS_Matches pm&#xA;;&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\mot_number NULL Case\PAT"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{7767d3e5-7895-4786-9893-173caa669e89}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="PAT"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{B06732EE-E98B-45E4-9826-B822D8836FA1}"
              SQLTask:SqlStatementSource="-- PSP-11073 Fix: Problem 2 — PAIMS Fallback Document Linking for PAT&#xA;&#xA;WITH PAT_NullMot_Docs AS (&#xA;    SELECT&#xA;        CONVERT(INT, A.LAND_PARCEL_ID) AS LAND_PARCEL_ID,&#xA;        CONVERT(VARCHAR(50), CONCAT(CONVERT(INT, A.LAND_PARCEL_ID), '-', 'NULL')) AS LEGACY_FILE_NUMBER,&#xA;        B.DOCUMENT_ID,&#xA;        slp.PID&#xA;    FROM etl.PAT_SOURCE_LAND_PARCEL A&#xA;    JOIN dbo.PIMS_DOCUMENT B&#xA;        ON A.MULTIMEDIA_OBJECT_ID = B.DOCUMENT_EXTERNAL_ID&#xA;    JOIN etl.SOURCE_LAND_PARCEL slp&#xA;        ON CONVERT(INT, slp.LAND_PARCEL_ID) = CONVERT(INT, A.LAND_PARCEL_ID)&#xA;        AND slp.SOURCE = 'PAT'&#xA;    WHERE A.MOT_NUMBER IS NULL&#xA;      -- Exclude documents already linked&#xA;      AND B.DOCUMENT_ID NOT IN (&#xA;          SELECT DOCUMENT_ID&#xA;          FROM dbo.PIMS_ACQUISITION_FILE_DOCUMENT&#xA;          WHERE APP_CREATE_USERID LIKE '%PAT%'&#xA;      )&#xA;      -- Exclude documents that already have a PAT ETL acquisition file&#xA;      AND NOT EXISTS (&#xA;          SELECT 1&#xA;          FROM dbo.PIMS_ACQUISITION_FILE af&#xA;          WHERE CONVERT(VARCHAR(50), af.LEGACY_FILE_NUMBER) = CONVERT(VARCHAR(50), CONCAT(CONVERT(INT, A.LAND_PARCEL_ID), '-', 'NULL'))&#xA;            AND LEFT(af.APP_CREATE_USERID, 3) = 'PAT'&#xA;      )&#xA;),&#xA;PAIMS_Matches AS (&#xA;    SELECT&#xA;        g.DOCUMENT_ID,&#xA;        g.LAND_PARCEL_ID,&#xA;        af.ACQUISITION_FILE_ID&#xA;    FROM PAT_NullMot_Docs g&#xA;    JOIN dbo.PIMS_PROPERTY pp&#xA;        ON pp.PID = TRY_CONVERT(int, g.PID)&#xA;    JOIN dbo.PIMS_PROPERTY_ACQUISITION_FILE ppaf&#xA;        ON ppaf.PROPERTY_ID = pp.PROPERTY_ID&#xA;    JOIN dbo.PIMS_ACQUISITION_FILE af&#xA;        ON af.ACQUISITION_FILE_ID = ppaf.ACQUISITION_FILE_ID&#xA;    WHERE af.APP_CREATE_USERID LIKE '%PAIMS_PIMS_ACQUISITION%'&#xA;)&#xA;&#xA;-- Preview before inserting&#xA;&#xA;--SELECT&#xA;--    pm.DOCUMENT_ID,&#xA;--    pm.ACQUISITION_FILE_ID,&#xA;--    pm.LAND_PARCEL_ID,&#xA;--    'PAT_ETL' AS APP_CREATE_USERID&#xA;--FROM PAIMS_Matches pm&#xA;--ORDER BY pm.LAND_PARCEL_ID, pm.DOCUMENT_ID&#xA;--;&#xA;&#xA;-- INSERT (run after validating preview above)&#xA;&#xA;INSERT INTO dbo.PIMS_ACQUISITION_FILE_DOCUMENT (&#xA;    DOCUMENT_ID,&#xA;    ACQUISITION_FILE_ID,&#xA;    APP_CREATE_USERID,&#xA;    APP_CREATE_TIMESTAMP,&#xA;    APP_LAST_UPDATE_USERID,&#xA;    APP_LAST_UPDATE_TIMESTAMP&#xA;)&#xA;SELECT&#xA;    pm.DOCUMENT_ID,&#xA;    pm.ACQUISITION_FILE_ID,&#xA;    'PAT_ETL',&#xA;    GETUTCDATE(),&#xA;    'PAT_ETL',&#xA;    GETUTCDATE()&#xA;FROM PAIMS_Matches pm&#xA;;&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\mot_number NULL Case\TAP"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{49df6c74-6736-4970-911c-7b9b5706fa2e}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="TAP"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{B06732EE-E98B-45E4-9826-B822D8836FA1}"
              SQLTask:SqlStatementSource="-- PSP-11073 Fix: Problem 2 — PAIMS Fallback Document Linking for TAP&#xA;&#xA;WITH TAP_NullMot_Docs AS (&#xA;    SELECT&#xA;        CONVERT(INT, A.LAND_PARCEL_ID) AS LAND_PARCEL_ID,&#xA;        CONVERT(VARCHAR(50), CONCAT(CONVERT(INT, A.LAND_PARCEL_ID), '-', 'NULL')) AS LEGACY_FILE_NUMBER,&#xA;        B.DOCUMENT_ID,&#xA;        slp.PID&#xA;    FROM etl.TAP_SOURCE_LAND_PARCEL A&#xA;    JOIN dbo.PIMS_DOCUMENT B&#xA;        ON A.MULTIMEDIA_OBJECT_ID = B.DOCUMENT_EXTERNAL_ID&#xA;    JOIN etl.SOURCE_LAND_PARCEL slp&#xA;        ON CONVERT(INT, slp.LAND_PARCEL_ID) = CONVERT(INT, A.LAND_PARCEL_ID)&#xA;        AND slp.SOURCE = 'TAP'&#xA;    WHERE A.MOT_NUMBER IS NULL&#xA;      -- Exclude documents already linked&#xA;      AND B.DOCUMENT_ID NOT IN (&#xA;          SELECT DOCUMENT_ID&#xA;          FROM dbo.PIMS_ACQUISITION_FILE_DOCUMENT&#xA;          WHERE APP_CREATE_USERID LIKE '%TAP%'&#xA;      )&#xA;      -- Exclude documents that already have a TAP ETL acquisition file&#xA;      AND NOT EXISTS (&#xA;          SELECT 1&#xA;          FROM dbo.PIMS_ACQUISITION_FILE af&#xA;          WHERE CONVERT(VARCHAR(50), af.LEGACY_FILE_NUMBER) = CONVERT(VARCHAR(50), CONCAT(CONVERT(INT, A.LAND_PARCEL_ID), '-', 'NULL'))&#xA;            AND LEFT(af.APP_CREATE_USERID, 3) = 'TAP'&#xA;      )&#xA;),&#xA;PAIMS_Matches AS (&#xA;    SELECT&#xA;        g.DOCUMENT_ID,&#xA;        g.LAND_PARCEL_ID,&#xA;        af.ACQUISITION_FILE_ID&#xA;    FROM TAP_NullMot_Docs g&#xA;    JOIN dbo.PIMS_PROPERTY pp&#xA;        ON pp.PID = TRY_CONVERT(int, g.PID)&#xA;    JOIN dbo.PIMS_PROPERTY_ACQUISITION_FILE ppaf&#xA;        ON ppaf.PROPERTY_ID = pp.PROPERTY_ID&#xA;    JOIN dbo.PIMS_ACQUISITION_FILE af&#xA;        ON af.ACQUISITION_FILE_ID = ppaf.ACQUISITION_FILE_ID&#xA;    WHERE af.APP_CREATE_USERID LIKE '%PAIMS_PIMS_ACQUISITION%'&#xA;)&#xA;&#xA;-- Preview before inserting&#xA;--SELECT&#xA;--    pm.DOCUMENT_ID,&#xA;--    pm.ACQUISITION_FILE_ID,&#xA;--    pm.LAND_PARCEL_ID,&#xA;--    'TAP_ETL' AS APP_CREATE_USERID&#xA;--FROM PAIMS_Matches pm&#xA;--ORDER BY pm.LAND_PARCEL_ID, pm.DOCUMENT_ID&#xA;--;&#xA;&#xA;-- INSERT (run after validating preview above)&#xA;&#xA;INSERT INTO dbo.PIMS_ACQUISITION_FILE_DOCUMENT (&#xA;    DOCUMENT_ID,&#xA;    ACQUISITION_FILE_ID,&#xA;    APP_CREATE_USERID,&#xA;    APP_CREATE_TIMESTAMP,&#xA;    APP_LAST_UPDATE_USERID,&#xA;    APP_LAST_UPDATE_TIMESTAMP&#xA;)&#xA;SELECT&#xA;    pm.DOCUMENT_ID,&#xA;    pm.ACQUISITION_FILE_ID,&#xA;    'TAP_ETL',&#xA;    GETUTCDATE(),&#xA;    'TAP_ETL',&#xA;    GETUTCDATE()&#xA;FROM PAIMS_Matches pm&#xA;;&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
      </DTS:Executables>
