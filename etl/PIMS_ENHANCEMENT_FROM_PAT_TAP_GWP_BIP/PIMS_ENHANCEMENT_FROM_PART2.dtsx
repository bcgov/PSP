        <SQLTask:SqlTaskData
          SQLTask:Connection="{B06732EE-E98B-45E4-9826-B822D8836FA1}"
          SQLTask:SqlStatementSource="with X as&#xA;(&#xA;SELECT &#xA; &#xA;&#x9;AF.ACQUISITION_FILE_ID, &#xA;&#x9;PP.PROPERTY_ID,&#xA;&#x9;PP.[LOCATION],&#xA;&#x9;AF.APP_CREATE_USERID&#xA;&#x9;&#xA;FROM&#xA;&#x9;dbo.PIMS_ACQUISITION_FILE AF&#xA;&#x9;JOIN etl.SOURCE_LAND_PARCEL SLP ON TRIM(AF.FILE_NAME) = TRIM(SLP.OWNER_NAME)&#xA;&#x9;LEFT JOIN dbo.PIMS_PROPERTY PP ON SLP.PID = PP.PID &#xA;&#xA;WHERE&#xA;&#xA;&#x9;AF.APP_CREATE_USERID like '%PIMS_PAT_TAP_GWP_ETL%'&#xA;)&#xA;&#xA;&#xA;&#xA;, Ranked AS (&#xA;    SELECT &#xA;        X.ACQUISITION_FILE_ID,&#xA;        X.PROPERTY_ID,&#xA;        X.APP_CREATE_USERID,&#xA;        X.[LOCATION],&#xA;        ROW_NUMBER() OVER (&#xA;            PARTITION BY X.ACQUISITION_FILE_ID, X.PROPERTY_ID, X.APP_CREATE_USERID&#xA;            ORDER BY (SELECT NULL)&#xA;        ) AS rn&#xA;    FROM X&#xA;    WHERE &#xA;        X.ACQUISITION_FILE_ID IS NOT NULL&#xA;        AND X.PROPERTY_ID IS NOT NULL&#xA;        AND NOT EXISTS (&#xA;            SELECT 1&#xA;            FROM dbo.PIMS_PROPERTY_ACQUISITION_FILE T&#xA;            WHERE&#xA;                T.ACQUISITION_FILE_ID = X.ACQUISITION_FILE_ID AND&#xA;                T.PROPERTY_ID = X.PROPERTY_ID AND&#xA;                T.APP_CREATE_USERID = X.APP_CREATE_USERID&#xA;        )&#xA;)&#xA;INSERT INTO dbo.PIMS_PROPERTY_ACQUISITION_FILE ( &#xA;    ACQUISITION_FILE_ID, &#xA;    PROPERTY_ID, &#xA;    APP_CREATE_USERID, &#xA;    APP_CREATE_TIMESTAMP, &#xA;    APP_LAST_UPDATE_USERID, &#xA;    APP_LAST_UPDATE_TIMESTAMP, &#xA;    APP_CREATE_USER_DIRECTORY, &#xA;    APP_LAST_UPDATE_USER_DIRECTORY,&#xA;    [LOCATION]&#xA;)&#xA;SELECT&#xA;    ACQUISITION_FILE_ID,&#xA;    PROPERTY_ID,&#xA;    APP_CREATE_USERID,&#xA;    GETDATE() AS APP_CREATE_TIMESTAMP, &#xA;    APP_CREATE_USERID AS APP_LAST_UPDATE_USERID, &#xA;    GETDATE() AS APP_LAST_UPDATE_TIMESTAMP, &#xA;    APP_CREATE_USERID AS APP_CREATE_USER_DIRECTORY, &#xA;    APP_CREATE_USERID AS APP_LAST_UPDATE_USER_DIRECTORY,&#xA;    [LOCATION]&#xA;FROM Ranked&#xA;WHERE rn = 1;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
