    <DTS:Executable
      DTS:refId="Package\2_PIMS_PROPERTY"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{C3A4A700-9291-478B-8688-1AAF0E7E330E}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="2_PIMS_PROPERTY"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{B06732EE-E98B-45E4-9826-B822D8836FA1}"
          SQLTask:SqlStatementSource="&#xA;    WITH &#xA;&#x9;&#xA;&#x9;PMBC AS (&#xA;&#x9;SELECT PID, SHAPE as BOUNDARY,&#x9;geometry::STGeomFromText(SHAPE.MakeValid().STCentroid().ToString(), SHAPE.STSrid) AS LOCATION&#xA;&#x9;FROM [pmbc].[PMBC_PARCEL_POLYGON_FABRIC]&#xA;&#x9;WHERE PID IN (  Select distinct PID FROM etl.SOURCE_LAND_PARCEL where PID is NOT null)&#xA;&#x9;)&#xA;&#x9;&#xA;&#x9;&#xA;&#x9;,RankedParcels AS (&#xA;        SELECT &#xA;            CAST('LAND' AS NVARCHAR(20)) AS [PROPERTY_TYPE_CODE],&#xA;            B.ADDRESS_ID,&#xA;            '4' AS REGION_CODE,&#xA;            '12' AS DISTRICT_CODE,&#xA;            CAST(A.[SOURCE] AS NVARCHAR(20)) AS PROPERTY_DATA_SOURCE_TYPE_CODE,&#xA;            CAST('UNKNOWN' AS NVARCHAR(20)) AS PROPERTY_STATUS_TYPE_CODE,&#xA;            CAST(A.CREATE_DATETIME AS DATE) AS PROPERTY_DATA_SOURCE_EFFECTIVE_DATE,&#xA;            --CASE WHEN A.OWNER_NAME IS NOT NULL THEN 1 ELSE 0 END AS IS_OWNED,&#xA;&#x9;&#x9;&#x9;&#xA;&#x9;&#x9;&#x9;CASE &#xA;                WHEN TRIM(A.ACQUISITION_STATUS_DESCRIPTION) IN (&#xA;&#x9;&#x9;&#x9;&#x9;'file_complete',&#xA;&#x9;&#x9;&#x9;&#x9;'ownership',&#xA;&#x9;&#x9;&#x9;&#x9;'ownership_(tenure)',&#xA;&#x9;&#x9;&#x9;&#x9;'settled',&#xA;&#x9;&#x9;&#x9;&#x9;'expropriated'&#xA;&#xA;&#x9;&#x9;&#x9;&#x9;) THEN 1 ELSE 0 &#xA;            END AS IS_OWNED,&#xA;&#x9;&#x9;&#x9;&#xA;&#x9;&#x9;&#x9;&#xA;            A.PID,&#xA;            A.SOURCE + '_PIMS_PAT_TAP_GWP_ETL' AS [APP_CREATE_USERID],&#xA;            GETDATE() AS [APP_CREATE_TIMESTAMP],&#xA;            A.SOURCE + '_PIMS_PAT_TAP_GWP_ETL' AS [APP_LAST_UPDATE_USERID],&#xA;            GETDATE() AS [APP_LAST_UPDATE_TIMESTAMP],&#xA;            'PIMS_PAT_TAP_GWP_ETL' AS [APP_CREATE_USER_DIRECTORY],&#xA;            'PIMS_PAT_TAP_GWP_ETL' AS [APP_LAST_UPDATE_USER_DIRECTORY],&#xA;            'UNKNOWN' AS SURPLUS_DECLARATION_TYPE_CODE,&#xA;&#x9;&#x9;&#x9;&#xA;&#x9;&#x9;&#x9;PMBC.BOUNDARY,&#xA;&#x9;&#x9;&#x9;PMBC.LOCATION,&#xA;            &#xA;            ROW_NUMBER() OVER (&#xA;                PARTITION BY A.PID, A.SOURCE &#xA;                ORDER BY A.CREATE_DATETIME DESC &#xA;            ) AS rn&#xA;&#xA;        FROM etl.SOURCE_LAND_PARCEL A&#xA;        LEFT JOIN dbo.PIMS_ADDRESS B &#xA;            ON (A.[SOURCE] + '-' + CAST(A.LAND_PARCEL_ID AS VARCHAR)) = B.COMMENT&#xA;        LEFT JOIN etl.SOURCE_LAND_PARCEL_GEOMETRY C &#xA;            ON A.LAND_PARCEL_ID = C.LAND_PARCEL_ID&#xA;&#x9;&#x9;LEFT JOIN PMBC &#xA;&#x9;&#x9;&#x9;ON A.PID = PMBC.PID&#xA;        WHERE A.PID IS NOT NULL&#xA;          -- Ensuring invalid geometries are excluded&#xA;          AND TRY_CONVERT(geometry, C.SHAPE_WKT) IS NOT NULL&#xA;    )&#xA;    INSERT INTO PIMS_PROPERTY&#xA;    (&#xA;        PROPERTY_TYPE_CODE,&#xA;        ADDRESS_ID,&#xA;        REGION_CODE,&#xA;        DISTRICT_CODE,&#xA;        PROPERTY_DATA_SOURCE_TYPE_CODE,&#xA;        PROPERTY_STATUS_TYPE_CODE,&#xA;        PROPERTY_DATA_SOURCE_EFFECTIVE_DATE,&#xA;        IS_OWNED,&#xA;        PID,&#xA;        BOUNDARY,&#xA;        [LOCATION],&#xA;        APP_CREATE_USERID,&#xA;        APP_CREATE_TIMESTAMP,&#xA;        APP_LAST_UPDATE_USERID,&#xA;        APP_LAST_UPDATE_TIMESTAMP,&#xA;        APP_CREATE_USER_DIRECTORY,&#xA;        APP_LAST_UPDATE_USER_DIRECTORY,&#xA;        SURPLUS_DECLARATION_TYPE_CODE&#xA;    )&#xA;    SELECT &#xA;        PROPERTY_TYPE_CODE,&#xA;        ADDRESS_ID,&#xA;        REGION_CODE,&#xA;        DISTRICT_CODE,&#xA;        PROPERTY_DATA_SOURCE_TYPE_CODE,&#xA;        PROPERTY_STATUS_TYPE_CODE,&#xA;        PROPERTY_DATA_SOURCE_EFFECTIVE_DATE,&#xA;        IS_OWNED,&#xA;        PID,&#xA;        BOUNDARY,&#xA;        [LOCATION],&#xA;        APP_CREATE_USERID,&#xA;        APP_CREATE_TIMESTAMP,&#xA;        APP_LAST_UPDATE_USERID,&#xA;        APP_LAST_UPDATE_TIMESTAMP,&#xA;        APP_CREATE_USER_DIRECTORY,&#xA;        APP_LAST_UPDATE_USER_DIRECTORY,&#xA;        SURPLUS_DECLARATION_TYPE_CODE&#xA;    FROM RankedParcels RP&#xA;    WHERE RP.rn = 1&#xA;      AND NOT EXISTS (&#xA;          SELECT 1 &#xA;          FROM PIMS_PROPERTY PP&#xA;          WHERE PP.PID = RP.PID&#xA;      );" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
