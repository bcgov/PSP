    <DTS:Executable
      DTS:refId="Package\EST_PIMS_PROPERTY_ACQUISITION_FILE"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{B157F10F-B310-45ED-A16E-1A1F93C20747}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="EST_PIMS_PROPERTY_ACQUISITION_FILE"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{B06732EE-E98B-45E4-9826-B822D8836FA1}"
          SQLTask:SqlStatementSource="with &#xA;&#xA;SLP AS &#xA;(&#xA;SELECT &#xA;     SOURCE,&#xA;&#x9; LAND_PARCEL_ID, &#xA;&#x9; PID, &#xA;&#x9; MOT_NUMBER,&#xA;&#x9;CASE &#xA;&#x9;&#x9;WHEN MOT_NUMBER IS NULL THEN CONVERT(VARCHAR(50), CONCAT( LAND_PARCEL_ID, '-', 'NULL'))&#xA;&#x9;&#x9;WHEN MOT_NUMBER IS NOT NULL THEN CONVERT(VARCHAR(50), CONCAT( LAND_PARCEL_ID, '-', CONVERT(INT,MOT_NUMBER) ))&#xA;&#x9;END AS LEGACY_FILE_NUMBER&#xA;&#xA;FROM etl.SOURCE_LAND_PARCEL &#xA;)&#xA;&#xA; &#xA;&#xA;, X as&#xA;(&#xA;SELECT &#xA; &#xA; AF.ACQUISITION_FILE_ID, &#xA; PP.PROPERTY_ID,&#xA; PP.[LOCATION],&#xA; AF.APP_CREATE_USERID&#xA; &#xA;FROM&#xA; dbo.PIMS_ACQUISITION_FILE AF&#xA; JOIN SLP ON AF.LEGACY_FILE_NUMBER = SLP.LEGACY_FILE_NUMBER AND left(AF.app_create_userid,3) = SLP.SOURCE -- TRIM(AF.FILE_NAME) = TRIM(SLP.OWNER_NAME)&#xA; LEFT JOIN dbo.PIMS_PROPERTY PP ON SLP.PID = PP.PID &#xA;&#xA;WHERE&#xA;&#xA; AF.APP_CREATE_USERID like '%_ETL%'&#xA;)&#xA;&#xA;&#xA;&#xA;, Ranked AS (&#xA;    SELECT &#xA;        X.ACQUISITION_FILE_ID,&#xA;        X.PROPERTY_ID,&#xA;        X.APP_CREATE_USERID,&#xA;        X.[LOCATION],&#xA;        ROW_NUMBER() OVER (&#xA;            PARTITION BY X.ACQUISITION_FILE_ID, X.PROPERTY_ID, X.APP_CREATE_USERID&#xA;            ORDER BY (SELECT NULL)&#xA;        ) AS rn&#xA;    FROM X&#xA;    WHERE &#xA;        X.ACQUISITION_FILE_ID IS NOT NULL&#xA;        AND X.PROPERTY_ID IS NOT NULL&#xA;        AND NOT EXISTS (&#xA;            SELECT 1&#xA;            FROM dbo.PIMS_PROPERTY_ACQUISITION_FILE T&#xA;            WHERE&#xA;                T.ACQUISITION_FILE_ID = X.ACQUISITION_FILE_ID AND&#xA;                T.PROPERTY_ID = X.PROPERTY_ID AND&#xA;                T.APP_CREATE_USERID = X.APP_CREATE_USERID&#xA;        )&#xA;)&#xA;INSERT INTO dbo.PIMS_PROPERTY_ACQUISITION_FILE ( &#xA;    ACQUISITION_FILE_ID, &#xA;    PROPERTY_ID, &#xA;    APP_CREATE_USERID, &#xA;    APP_CREATE_TIMESTAMP, &#xA;    APP_LAST_UPDATE_USERID, &#xA;    APP_LAST_UPDATE_TIMESTAMP, &#xA;    APP_CREATE_USER_DIRECTORY, &#xA;    APP_LAST_UPDATE_USER_DIRECTORY,&#xA;    [LOCATION]&#xA;)&#xA;SELECT  &#xA;    ACQUISITION_FILE_ID,&#xA;    PROPERTY_ID,&#xA;    APP_CREATE_USERID,&#xA;    GETDATE() AS APP_CREATE_TIMESTAMP, &#xA;    APP_CREATE_USERID AS APP_LAST_UPDATE_USERID, &#xA;    GETDATE() AS APP_LAST_UPDATE_TIMESTAMP, &#xA;    APP_CREATE_USERID AS APP_CREATE_USER_DIRECTORY, &#xA;    APP_CREATE_USERID AS APP_LAST_UPDATE_USER_DIRECTORY,&#xA;    [LOCATION]&#xA;FROM Ranked&#xA;WHERE rn = 1;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\EST_PIMS_PROPERTY_SUB_INTEREST_PIDs"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{02532687-696A-4761-9C4E-60E6B03C85FD}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="EST_PIMS_PROPERTY_SUB_INTEREST_PIDs"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{B06732EE-E98B-45E4-9826-B822D8836FA1}"
          SQLTask:SqlStatementSource="&#xA;    WITH &#xA;&#x9;&#xA;&#x9;PMBC AS (&#xA;&#x9;SELECT PID, SHAPE as BOUNDARY,&#x9;geometry::STGeomFromText(SHAPE.MakeValid().STCentroid().ToString(), SHAPE.STSrid) AS LOCATION&#xA;&#x9;FROM [pmbc].[PMBC_PARCEL_POLYGON_FABRIC]&#xA;&#x9;WHERE PID IN (  Select distinct PID FROM etl.SOURCE_SUB_INTEREST where PID is NOT null)&#xA;&#x9;)&#xA;&#x9;&#xA;&#x9;&#xA;&#x9;,RankedParcels AS (&#xA;        SELECT &#xA;            CAST('LAND' AS NVARCHAR(20)) AS [PROPERTY_TYPE_CODE],&#xA;            B.ADDRESS_ID,&#xA;            '4' AS REGION_CODE,&#xA;            '12' AS DISTRICT_CODE,&#xA;            CAST(A.[SOURCE] AS NVARCHAR(20)) AS PROPERTY_DATA_SOURCE_TYPE_CODE,&#xA;            CAST('UNKNOWN' AS NVARCHAR(20)) AS PROPERTY_STATUS_TYPE_CODE,&#xA;            CAST(A.CREATE_DATETIME AS DATE) AS PROPERTY_DATA_SOURCE_EFFECTIVE_DATE,&#xA;            --CASE WHEN A.OWNER_NAME IS NOT NULL THEN 1 ELSE 0 END AS IS_OWNED,&#xA;&#x9;&#x9;&#x9;&#xA;&#x9;&#x9;&#x9;CASE &#xA;                -- WHEN TRIM(A.ACQUISITION_STATUS_DESCRIPTION) IN (&#xA;&#x9;&#x9;&#x9;&#x9;WHEN TRIM(A.TAKING_TYPE) IN (&#xA;&#x9;&#x9;&#x9;&#x9;-- source_land_parcel&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;--'file_complete',&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;--'ownership',&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;--'ownership_(tenure)',&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;--'settled',&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;--'expropriated',&#xA;&#xA;&#x9;&#x9;&#x9;&#x9;-- source_sub_interest -- question &#xA;&#x9;&#x9;&#x9;&#x9;&#x9;'License Only',&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;'Not Required',&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;'Other Disturbance',&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;'Partial Acquisition',&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;'Statutory Right of Way',&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;'Temporary SRW',&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;'Total Aquisition',&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;'Unknown'&#xA;&#xA;&#x9;&#x9;&#x9;&#x9;) THEN 1 ELSE 0 &#xA;            END AS IS_OWNED,&#xA;&#x9;&#x9;&#x9;&#xA;&#x9;&#x9;&#x9;&#xA;            A.PID,&#xA;            A.SOURCE + '_PIMS_PAT_TAP_GWP_ETL' AS [APP_CREATE_USERID],&#xA;            GETDATE() AS [APP_CREATE_TIMESTAMP],&#xA;            A.SOURCE + '_PIMS_PAT_TAP_GWP_ETL' AS [APP_LAST_UPDATE_USERID],&#xA;            GETDATE() AS [APP_LAST_UPDATE_TIMESTAMP],&#xA;            'PIMS_PAT_TAP_GWP_ETL' AS [APP_CREATE_USER_DIRECTORY],&#xA;            'PIMS_PAT_TAP_GWP_ETL' AS [APP_LAST_UPDATE_USER_DIRECTORY],&#xA;            'UNKNOWN' AS SURPLUS_DECLARATION_TYPE_CODE,&#xA;&#x9;&#x9;&#x9;&#xA;&#x9;&#x9;&#x9;PMBC.BOUNDARY,&#xA;&#x9;&#x9;&#x9;PMBC.LOCATION,&#xA;            &#xA;            ROW_NUMBER() OVER (&#xA;                PARTITION BY A.PID, A.SOURCE &#xA;                ORDER BY A.CREATE_DATETIME DESC &#xA;            ) AS rn&#xA;&#xA;        FROM etl.SOURCE_SUB_INTEREST A&#xA;        LEFT JOIN dbo.PIMS_ADDRESS B &#xA;            ON (A.[SOURCE] + '-' + CAST(A.LAND_PARCEL_ID AS VARCHAR)) = B.COMMENT&#xA;        --LEFT JOIN etl.SOURCE_SUB_INTEREST_GEOMETRY C &#xA;        --    ON A.LAND_PARCEL_ID = C.LAND_PARCEL_ID&#xA;&#x9;&#x9;LEFT JOIN PMBC &#xA;&#x9;&#x9;&#x9;ON A.PID = PMBC.PID&#xA;        WHERE A.PID IS NOT NULL&#xA;          -- Ensuring invalid geometries are excluded&#xA;          -- AND TRY_CONVERT(geometry, C.SHAPE_WKT) IS NOT NULL&#xA;    )&#xA;     INSERT INTO PIMS_PROPERTY&#xA;     (&#xA;         PROPERTY_TYPE_CODE,&#xA;         ADDRESS_ID,&#xA;         REGION_CODE,&#xA;         DISTRICT_CODE,&#xA;         PROPERTY_DATA_SOURCE_TYPE_CODE,&#xA;         PROPERTY_STATUS_TYPE_CODE,&#xA;         PROPERTY_DATA_SOURCE_EFFECTIVE_DATE,&#xA;         IS_OWNED,&#xA;         PID,&#xA;         BOUNDARY,&#xA;         [LOCATION],&#xA;         APP_CREATE_USERID,&#xA;         APP_CREATE_TIMESTAMP,&#xA;         APP_LAST_UPDATE_USERID,&#xA;         APP_LAST_UPDATE_TIMESTAMP,&#xA;         APP_CREATE_USER_DIRECTORY,&#xA;         APP_LAST_UPDATE_USER_DIRECTORY,&#xA;         SURPLUS_DECLARATION_TYPE_CODE&#xA;     )&#xA;    SELECT &#xA;        PROPERTY_TYPE_CODE,&#xA;        ADDRESS_ID,&#xA;        REGION_CODE,&#xA;        DISTRICT_CODE,&#xA;        PROPERTY_DATA_SOURCE_TYPE_CODE,&#xA;        PROPERTY_STATUS_TYPE_CODE,&#xA;        PROPERTY_DATA_SOURCE_EFFECTIVE_DATE,&#xA;        IS_OWNED,&#xA;        PID,&#xA;        BOUNDARY,&#xA;        [LOCATION],&#xA;        APP_CREATE_USERID,&#xA;        APP_CREATE_TIMESTAMP,&#xA;        APP_LAST_UPDATE_USERID,&#xA;        APP_LAST_UPDATE_TIMESTAMP,&#xA;        APP_CREATE_USER_DIRECTORY,&#xA;        APP_LAST_UPDATE_USER_DIRECTORY,&#xA;        SURPLUS_DECLARATION_TYPE_CODE&#xA;    FROM RankedParcels RP&#xA;    WHERE RP.rn = 1&#xA;      AND NOT EXISTS (&#xA;          SELECT 1 &#xA;          FROM PIMS_PROPERTY PP&#xA;          WHERE PP.PID = RP.PID&#xA;      );" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
