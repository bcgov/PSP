                  expressionType="Notify"
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT  [DOCUMENT_ID] ,	[ACQUISITION_FILE_ID] 
FROM 
dbo.PIMS_ACQUISITION_FILE_DOCUMENT;</property>
                <property
                  dataType="System.String"
                  description="Specifies a SQL statement that uses parameters to generate the lookup table."
                  expressionType="Notify"
                  name="SqlCommandParam"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">select * from (SELECT  [DOCUMENT_ID] ,	[ACQUISITION_FILE_ID] 
FROM 
dbo.PIMS_ACQUISITION_FILE_DOCUMENT;) [refTable]
where [refTable].[DOCUMENT_ID] = ? and [refTable].[ACQUISITION_FILE_ID] = ?</property>
