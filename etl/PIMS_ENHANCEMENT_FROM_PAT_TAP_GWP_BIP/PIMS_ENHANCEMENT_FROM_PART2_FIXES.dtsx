                  <outputs>
                    <output
                      refId="Package\SEQ_2_PIMS_ACQUISITION_FILE\DF_CASE2_PARENT_NULL_PID_NOTNULL\OLE DB Source.Outputs[OLE DB Source Output]"
                      name="OLE DB Source Output">
                      <outputColumns>
                        <outputColumn
                          refId="Package\SEQ_2_PIMS_ACQUISITION_FILE\DF_CASE2_PARENT_NULL_PID_NOTNULL\OLE DB Source.Outputs[OLE DB Source Output].Columns[ACQUISITION_FILE_STATUS_TYPE_CODE]"
                          dataType="wstr"
