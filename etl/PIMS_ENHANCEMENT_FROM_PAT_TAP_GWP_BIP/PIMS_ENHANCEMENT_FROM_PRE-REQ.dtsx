        <SQLTask:SqlTaskData
          SQLTask:Connection="{B06732EE-E98B-45E4-9826-B822D8836FA1}"
          SQLTask:SqlStatementSource="IF NOT EXISTS (&#xA;    SELECT 1 &#xA;    FROM INFORMATION_SCHEMA.TABLES &#xA;    WHERE TABLE_NAME = 'SOURCE_LAND_PARCEL' AND TABLE_SCHEMA = 'etl'&#xA;)&#xA;BEGIN&#xA;    CREATE TABLE etl.SOURCE_LAND_PARCEL (&#xA;    [LAND_PARCEL_ID] numeric(6,0),&#xA;    [PID] nvarchar(12),&#xA;    [OTHER_PID] nvarchar(50),&#xA;    [PARCEL_INDEX] nvarchar(50),&#xA;    [MOT_NUMBER] numeric(38,8),&#xA;    [OWNER_NAME] nvarchar(240),&#xA;    [PREVIOUS_OWNER_NAME] nvarchar(240),&#xA;    [OTHER_OWNER_NAME] nvarchar(240),&#xA;    [ALIAS_NAME] nvarchar(240),&#xA;    [ADDRESS] nvarchar(240),&#xA;    [ACQUISITION_STATUS_DESCRIPTION] nvarchar(50),&#xA;    [AGREEMENT_TYPE] nvarchar(50),&#xA;    [CONSTRUCTION_COMMITMENT_DESC] nvarchar(50),&#xA;    [ACTUAL_PAID] numeric(11,2),&#xA;    [REQUIRED_DATE] datetime,&#xA;    [TAKING_TYPE] nvarchar(50),&#xA;    [APPRAISAL_REQUIRED_DESC] nvarchar(10),&#xA;    [SECTION_6_RISK] nvarchar(9),&#xA;    [SURPLUS_DESCRIPTION] nvarchar(17),&#xA;    [LEGAL_SURVEY_STATUS_DESC] nvarchar(50),&#xA;    [ESTIMATED_DATE] datetime,&#xA;    [SURPLUS_VALUE] numeric(17,2),&#xA;    [POSSESSION_DATE] datetime,&#xA;    [NOTE] nvarchar(255),&#xA;    [AGENT_NAME] nvarchar(240),&#xA;    [CREATE_USERID] nvarchar(30),&#xA;    [CREATE_DATETIME] datetime,&#xA;    [LAST_UPDATE_USERID] nvarchar(30),&#xA;    [LAST_UPDATE_DATETIME] datetime,&#xA;    [LAST_UPDATE_APP_USERID] nvarchar(30),&#xA;    [INITIAL_ESTIMATE_AMOUNT] numeric(11,2),&#xA;    [ADVANCE_PAYMENT_DATE] datetime,&#xA;    [LAND_UNIT_RATE_PAID_AMOUNT] numeric(11,2),&#xA;    [OWNERSHIP_TYPE_DESCRIPTION] nvarchar(30),&#xA;    [ACQUISITION_PRIORITY_DESC] nvarchar(30),&#xA;    [STRATA_PLAN_NUMBER] nvarchar(8),&#xA;    [GEOMETRY_EXISTENCE_FLAG] nvarchar(1),&#xA;    [SOURCE] nvarchar(3)&#xA;);&#xA;END;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
